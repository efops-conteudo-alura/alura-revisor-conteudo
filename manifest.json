{
  "manifest_version": 3,
  "name": "Revisor de Conteúdo ",
  "version": "0.3.4",
  "update_url": "https://hub-producao-conteudo.vercel.app/update.xml",
  "description": "Realiza a revisão dos cursos da Alura, garantindo que estejam alinhados aos padrões de qualidade e corrigindo eventuais erros.",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "downloads", "identity"],
  "host_permissions": ["https://cursos.alura.com.br/*", "https://app.aluracursos.com/*", "https://*/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Alura Revisor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://cursos.alura.com.br/*", "https://app.aluracursos.com/*"],
      "js": ["content.js", "content-admin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.dropbox.com/*"],
      "js": ["content-dropbox.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hub-producao-conteudo.vercel.app/*"],
      "js": ["content-hub.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://ferramentas-ia.alura.dev/*"],
      "js": ["content-ferramentas-ia.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg", "injected-ferramentas-ia.js"],
      "matches": ["https://cursos.alura.com.br/*", "https://app.aluracursos.com/*", "https://www.dropbox.com/*", "https://hub-producao-conteudo.vercel.app/*", "https://ferramentas-ia.alura.dev/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "revisor-conteudo@alura.com.br",
      "strict_min_version": "121.0"
    }
  }
}
