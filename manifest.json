{
  "manifest_version": 3,
  "name": "Revisor de Conteúdo ",
  "version": "0.1.0",
  "description": "Realiza a revisão dos cursos da Alura, garantindo que estejam alinhados aos padrões de qualidade e corrigindo eventuais erros.",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "downloads"],
  "host_permissions": ["https://cursos.alura.com.br/*", "<all_urls>"],
  "action": {
    "default_title": "Alura Revisor",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cursos.alura.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://cursos.alura.com.br/*"]
    }
  ]
}