{
  "manifest_version": 3,
  "name": "Revisor de Conteúdo ",
  "version": "0.2.0",
  "description": "Realiza a revisão dos cursos da Alura, garantindo que estejam alinhados aos padrões de qualidade e corrigindo eventuais erros.",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "downloads"],
  "host_permissions": ["https://cursos.alura.com.br/*", "https://app.aluracursos.com/*", "https://*/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Alura Revisor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://cursos.alura.com.br/*", "https://app.aluracursos.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://cursos.alura.com.br/*", "https://app.aluracursos.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "revisor-conteudo@alura.com.br",
      "strict_min_version": "121.0"
    }
  }
}
